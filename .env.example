# このファイルを .env にコピーして値を設定する
# cp .env.example .env

# 本番URL(OGP・metadataBaseの基準)
NEXT_PUBLIC_URL=http://localhost:3000

# SSGform などフォーム送信先URL(お問い合わせフォーム)
NEXT_PUBLIC_SSG_FORM=

# WordPress REST API(お知らせ機能を使う場合)
# 例) https://example.com/wp-json/wp/v2/posts
WORDPRESS_POST_URL=
# 例) https://example.com/wp-json/wp/v2/categories
WORDPRESS_CATEGORIES_URL=

# microCMS(microCMSを使う場合)
MICROCMS_SERVICE_DOMAIN=
MICROCMS_API_KEY=
